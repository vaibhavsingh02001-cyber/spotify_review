# Environment Variables — Weekly Review Pulse AI Agent (MCP)
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ──────────────────────────────────────────────
# LLM Provider (Groq)
# ──────────────────────────────────────────────
GROQ_API_KEY=

# ──────────────────────────────────────────────
# Google Cloud / OAuth (for MCP integration)
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=

# ──────────────────────────────────────────────
# Agent Configuration
# ──────────────────────────────────────────────
REVIEW_WINDOW_WEEKS=10
LLM_CORPUS_CAP=1000
OPERATOR_EMAIL=
