# Environment Variables — Weekly Review Pulse AI Agent (MCP)
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ──────────────────────────────────────────────
# LLM Provider (Groq)
# ──────────────────────────────────────────────
GROQ_API_KEY=

# ──────────────────────────────────────────────
# Google Cloud / OAuth (for MCP integration)
# MCP Server: https://mcpserver-lopftmp3qyw6maunexx63v.streamlit.app/
#
# How to populate these values:
#   1. Complete the OAuth flow (via MCP Server or gcloud CLI)
#   2. Copy values from the generated token.json file:
#      client_id     → GOOGLE_CLIENT_ID
#      client_secret → GOOGLE_CLIENT_SECRET
#      token         → GOOGLE_ACCESS_TOKEN   (refreshed automatically)
#      refresh_token → GOOGLE_REFRESH_TOKEN
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
MCP_SERVER_URL=https://mcpserver-lopftmp3qyw6maunexx63v.streamlit.app/

# ──────────────────────────────────────────────
# Agent Configuration
# ──────────────────────────────────────────────
REVIEW_WINDOW_WEEKS=10
LLM_CORPUS_CAP=1000
OPERATOR_EMAIL=
